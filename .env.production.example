# ============================================================
# zippp.link — Production Environment Variables
# Copy this to Vercel > Project Settings > Environment Variables
# ============================================================

# ─── Database (Neon) ────────────────────────────────────────
# Get from: neon.tech → Your Project → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
# Use the "Direct connection" string for DIRECT_DATABASE_URL (for migrations)
DATABASE_URL=postgresql://<user>:<password>@<pooler-host>/neondb?sslmode=require
DIRECT_DATABASE_URL=postgresql://<user>:<password>@<direct-host>/neondb?sslmode=require

# ─── Auth (NextAuth) ────────────────────────────────────────
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=https://zippp.link
NEXTAUTH_SECRET=<your-generated-secret>

# ─── Google OAuth ───────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://zippp.link/api/auth/callback/google
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ─── Payments (Polar.sh) ────────────────────────────────────
# Get from: polar.sh → Dashboard → Products → Your product ID
# Webhook endpoint to set in Polar: https://zippp.link/api/webhooks/polar
POLAR_PRODUCT_ID=<your-polar-product-id>
POLAR_WEBHOOK_SECRET=<your-polar-webhook-secret>

# ─── Storage (Cloudflare R2) ────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# STORAGE_ENDPOINT format: https://<account-id>.r2.cloudflarestorage.com
# STORAGE_PUBLIC_URL: Your R2 bucket's public domain (set in R2 → Bucket → Settings → Public Access)
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=<r2-access-key-id>
STORAGE_SECRET_KEY=<r2-secret-access-key>
STORAGE_BUCKET=zippp-prod
STORAGE_PUBLIC_URL=https://assets.zippp.link

# ─── AI (Groq) — Optional ───────────────────────────────────
# Get from: console.groq.com
GROQ_API_KEY=<your-groq-api-key>

# ─── Email (Resend) — Optional ──────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=<your-resend-api-key>
